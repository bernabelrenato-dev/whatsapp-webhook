@echo off
gcloud compute ssh jgis-chatbot-server --zone=us-central1-a --command "sudo docker exec -i jgis-webhook node -e \"const axios=require('axios'),config=require('./src/config/environment');(async()=>{const u=config.CHATWOOT_API_URL+'/api/v1/accounts/'+config.CHATWOOT_ACCOUNT_ID+'/conversations',r=await axios.get(u,{headers:{api_access_token:config.CHATWOOT_ACCESS_TOKEN}}),c=r.data.data.payload;for(let i=0;i<Math.min(3,c.length);i++){console.log('=== CONV '+c[i].id+' ('+c[i].meta.sender.name+') ===');const mu=config.CHATWOOT_API_URL+'/api/v1/accounts/'+config.CHATWOOT_ACCOUNT_ID+'/conversations/'+c[i].id+'/messages',mr=await axios.get(mu,{headers:{api_access_token:config.CHATWOOT_ACCESS_TOKEN}}),ms=mr.data.payload;for(let m of ms.slice(-15))console.log('  ['+m.id+'] type:'+m.message_type+' -> '+(m.content?m.content.substring(0,50).replace(/\n/g,' '):'[Media]'));}})()\""
