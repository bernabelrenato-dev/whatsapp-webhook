{
  "output": {
    "filePath": "project-context.md",
    "style": "markdown",
    "removeComments": true,
    "removeEmptyLines": true,
    "showLineNumbers": true
  },
  "ignore": {
    "customPatterns": [
      "node_modules/**",
      ".git/**",
      "src/public/images/**",
      "scratch/**",
      ".agents/**",
      "src/config/catalog.json",
      "package-lock.json",
      "repomix-output.xml",
      "project-context.md",
      "scripts/database/*.sql",
      "scripts/extract/**",
      "*.log"
    ]
  }
}
